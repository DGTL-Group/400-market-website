# ── Payload CMS ──
PAYLOAD_SECRET=

# ── PostgreSQL (self-hosted on VPS) ──
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URI=postgresql://payload:password@localhost:5432/400market

# ── Cloudinary ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Stripe ──
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── AWS SES ──
AWS_SES_REGION=
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
AWS_SES_FROM_EMAIL=

# ── Plausible Analytics ──
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=400market.com
NEXT_PUBLIC_PLAUSIBLE_URL=https://plausible.dgtlgroup.io

# ── Meta Pixel ──
NEXT_PUBLIC_META_PIXEL_ID=

# ── App ──
