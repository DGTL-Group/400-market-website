# ── Payload CMS ──
PAYLOAD_SECRET=

# ── PostgreSQL (self-hosted on VPS) ──
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
# The VPS policy is TLS-required for any external IP — `?sslmode=require`
# is mandatory unless connecting over a Tailscale/private network.
DATABASE_URI=postgresql://payload:password@localhost:5432/400market?sslmode=require

# ── Cloudinary ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Stripe ──
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── AWS SES ──
AWS_SES_REGION=
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
AWS_SES_FROM_EMAIL=

# ── n8n (self-hosted on DGTL VPS) ──
N8N_BASE_URL=https://flow.400market.com
N8N_API_KEY=

# ── Plausible Analytics ──
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=400market.com
NEXT_PUBLIC_PLAUSIBLE_URL=https://plausible.dgtlgroup.io
PLAUSIBLE_API_KEY=

# ── Meta Pixel ──
NEXT_PUBLIC_META_PIXEL_ID=

# ── App ──
# Staging:    https://400market.dgtlgroup.io
# Production: https://400market.com
NEXT_PUBLIC_SITE_URL=https://400market.dgtlgroup.io
NODE_ENV=production
PORT=3000
